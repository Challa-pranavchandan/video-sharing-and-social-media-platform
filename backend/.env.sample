# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
# The port where the backend server will listen for requests.
# Default: 8000
PORT=8000

# ==============================================================================
# DATABASE CONFIGURATION (MongoDB)
# ==============================================================================
# Your MongoDB connection string. 
# If using MongoDB Atlas, it should look like: mongodb+srv://<user>:<password>@cluster.mongodb.net
# Note: The database name (e.g. 'videotube') is usually appended in the code.
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.abcde.mongodb.net

# ==============================================================================
# SECURITY & CORS
# ==============================================================================
# The URL of your frontend application. This is used to allow Cross-Origin requests.
# For local React development, this is typically http://localhost:5173
cors_origin=http://localhost:5173

# ==============================================================================
# AUTHENTICATION (JSON Web Tokens)
# ==============================================================================
# ACCESS_TOKEN_SECRET: A strong, unique secret key used to sign access tokens.
# Tip: You can generate one using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=your_long_random_access_token_secret_here
ACCESS_TOKEN_EXPIRES_IN=1d

# REFRESH_TOKEN_SECRET: A strong secret key used to sign refresh tokens.
REFRESH_TOKEN_SECRET=your_long_random_refresh_token_secret_here
REFRESH_TOKEN_EXPIRES_IN=10d

# ==============================================================================
# CLOUDINARY CONFIGURATION (Media Storage)
# ==============================================================================
# Cloudinary is used to store and serve images (avatars, thumbnails) and videos.
# Get these from your Cloudinary Dashboard (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
